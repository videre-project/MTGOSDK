<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
    <TargetFramework>$(_MTGOSDKCoreTFM)</TargetFramework>
    <LangVersion>Latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <IsPackable>false</IsPackable>
    <UseILRepack>true</UseILRepack>
    <ILRepackUnion>true</ILRepackUnion>
    <EnableMTGOSDKTracing Condition="'$(EnableMTGOSDKTracing)' == ''">false</EnableMTGOSDKTracing>
    <DefineConstants Condition="'$(EnableMTGOSDKTracing)' == 'true'">$(DefineConstants);MTGOSDK_TRACING</DefineConstants>
  </PropertyGroup>

  <!-- ILLink trimmer -->
  <!-- <PropertyGroup>
    <UseILLinkTrim>true</UseILLinkTrim>
  </PropertyGroup>
  <Import Project="$(ToolsDir)\ILLink\ILLink.targets"
          Condition="'$(UseILLinkTrim)' == 'true'" /> -->

  <!-- Merge the ScubaDiver assembly with ClrMD and other dependencies -->
  <Import Project="$(_ILRepackTargetsPath)" />
  <PropertyGroup>
    <ILRepackTarget>Microsoft.Diagnostics.Runtime</ILRepackTarget>
    <ILRepackOutput>$(SolutionDir)dist/$(Configuration)/$(RuntimeIdentifier)/$(ILRepackTarget).dll</ILRepackOutput>
    <UnmergedArtifactOutput>$(SolutionDir)dist/$(Configuration)/unmerged/$(AssemblyName).dll</UnmergedArtifactOutput>
    <SystemValueTuplePayloadVersion>4.5.0</SystemValueTuplePayloadVersion>
    <SystemValueTuplePayloadDll>$(NuGetPackageRoot)system.valuetuple\$(SystemValueTuplePayloadVersion)\lib\net461\System.ValueTuple.dll</SystemValueTuplePayloadDll>
  </PropertyGroup>

  <!-- Ensure Harmony is internalized into the single ClrMD injection payload. -->
  <Target Name="ValidateHarmonyMergeInput"
          AfterTargets="ComputeInputAssemblies"
          BeforeTargets="MergeReferenceAssemblies"
          Condition="'$(UseILRepack)' == 'true'">
    <ItemGroup>
      <HarmonyInputAssemblies Include="@(InputAssemblies)"
                              Condition="'%(InputAssemblies.Filename)' == '0Harmony'" />
    </ItemGroup>
    <Error Condition="'@(HarmonyInputAssemblies)' == ''"
           Text="Harmony was not included in the ScubaDiver ILRepack inputs. Restore Lib.Harmony before building ScubaDiver." />
  </Target>

  <!-- Remove payloads produced by older builds that shipped Harmony separately. -->
  <Target Name="RemoveLegacyHarmonyPayload"
          AfterTargets="MergeReferenceAssemblies;BuildArtifactDirectory">
    <Delete Files="$(SolutionDir)dist/$(Configuration)/0Harmony.dll" />
  </Target>

  <!--
    System.ValueTuple is not copy-local on net48 — NuGet treats it as a framework
    overlay and omits it from the build output. ILRepack therefore cannot
    internalize it and leaves a dangling external reference in the merged DLL,
    causing a FileNotFoundException when the Diver is injected into the MTGO process.

    Copy the DLL from the NuGet package to the dist directory so it is picked up
    by MTGOSDK's EmbedResources target, embedded as a resource, and extracted
    alongside the Diver at injection time for the AssemblyResolve handler to find.
  -->
  <Target Name="PackSystemValueTuple"
          AfterTargets="ResolveReferences"
          BeforeTargets="AfterBuild">
    <Error Condition="!Exists('$(SystemValueTuplePayloadDll)')"
           Text="System.ValueTuple payload not found at $(SystemValueTuplePayloadDll). Restore the System.ValueTuple $(SystemValueTuplePayloadVersion) PackageDownload before building ScubaDiver." />
    <Copy SourceFiles="$(SystemValueTuplePayloadDll)"
          DestinationFolder="$(SolutionDir)dist/$(Configuration)"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="BuildArtifactDirectory"
          AfterTargets="AfterBuild"
          Condition="'$(UseILRepack)' != 'true'">
    <MakeDir Directories="$([System.IO.Path]::GetDirectoryName('$(UnmergedArtifactOutput)'))" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll"
          DestinationFiles="$(UnmergedArtifactOutput)" />
  </Target>

  <ItemGroup>
    <PackageReference Include="System.Diagnostics.DiagnosticSource" />
    <PackageReference Include="System.IO.Pipelines" />
    <!-- Referenced for $(PkgSystem_ValueTuple) path only; ExcludeAssets="runtime"
         keeps it out of the build output (it is shipped via PackSystemValueTuple). -->
    <PackageReference Include="System.ValueTuple"
                      GeneratePathProperty="true"
                      ExcludeAssets="runtime" />
    <PackageDownload Include="System.ValueTuple" Version="[4.5.0]" />
    <PackageReference Include="Microsoft.Diagnostics.Runtime" />
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies"
                      PrivateAssets="All" />
    <PackageReference Include="MessagePack" />
    <PackageReference Include="MessagePack.Annotations" />
    <PackageReference Include="Lib.Harmony" />
    <ProjectReference Include="$(SolutionDir)\MTGOSDK\lib\MTGOSDK.Core\MTGOSDK.Core.csproj"
                      SetTargetFramework="TargetFramework=$(_MTGOSDKCoreTFM)" />
    <ProjectReference Include="$(SolutionDir)\MTGOSDK.Win32\MTGOSDK.Win32.csproj" />
  </ItemGroup>

  <!-- WPF assemblies for Dispatcher support -->
  <ItemGroup>
    <Reference Include="WindowsBase" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
  </ItemGroup>

</Project>
