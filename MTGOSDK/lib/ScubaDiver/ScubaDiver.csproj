<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
    <TargetFramework>$(_MTGOSDKCoreTFM)</TargetFramework>
    <LangVersion>Latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <IsPackable>false</IsPackable>
    <UseILRepack>true</UseILRepack>
  </PropertyGroup>

  <!-- ILLink trimmer -->
  <!-- <PropertyGroup>
    <UseILLinkTrim>true</UseILLinkTrim>
  </PropertyGroup>
  <Import Project="$(ToolsDir)\ILLink\ILLink.targets"
          Condition="'$(UseILLinkTrim)' == 'true'" /> -->

  <!-- Merge the ScubaDiver assembly with ClrMD and other dependencies -->
  <Import Project="$(_ILRepackTargetsPath)" />
  <PropertyGroup>
    <ILRepackTarget>Microsoft.Diagnostics.Runtime</ILRepackTarget>
    <HarmonyAssembly>bin/$(Configuration)/$(_MTGOSDKCoreTFM)/$(RuntimeIdentifier)/0Harmony.dll</HarmonyAssembly>
    <ILRepackOutput>$(SolutionDir)dist/$(Configuration)/$(RuntimeIdentifier)/$(ILRepackTarget).dll</ILRepackOutput>
  </PropertyGroup>

  <!-- Export the Harmony assembly to the output directory for packing -->
  <Target Name="PackHarmonyLib"
          AfterTargets="ComputeInputAssemblies"
          BeforeTargets="MergeReferenceAssemblies">
    <ItemGroup>
      <InputAssemblies Remove="$(HarmonyAssembly)" />
    </ItemGroup>
    <Copy SourceFiles="$(HarmonyAssembly)"
          DestinationFolder="$(SolutionDir)dist/$(Configuration)" />
  </Target>

  <!--
    System.ValueTuple is not copy-local on net48 — NuGet treats it as a framework
    overlay and omits it from the build output. ILRepack therefore cannot
    internalize it and leaves a dangling external reference in the merged DLL,
    causing a FileNotFoundException when the Diver is injected into the MTGO process.

    Copy the DLL from the NuGet package to the dist directory so it is picked up
    by MTGOSDK's EmbedResources target, embedded as a resource, and extracted
    alongside the Diver at injection time for the AssemblyResolve handler to find.
  -->
  <Target Name="PackSystemValueTuple"
          AfterTargets="AfterBuild">
    <ItemGroup>
      <ValueTupleDll Include="$(PkgSystem_ValueTuple)\lib\net462\System.ValueTuple.dll"
                     Condition="Exists('$(PkgSystem_ValueTuple)\lib\net462\System.ValueTuple.dll')" />
    </ItemGroup>
    <Copy SourceFiles="@(ValueTupleDll)"
          DestinationFolder="$(SolutionDir)dist/$(Configuration)"
          SkipUnchangedFiles="true"
          Condition="'@(ValueTupleDll)' != ''" />
  </Target>

  <Target Name="BuildArtifactDirectory"
          AfterTargets="AfterBuild"
          Condition="'$(UseILRepack)' != 'true'">
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll"
          DestinationFiles="$(ILRepackOutput)" />
  </Target>

  <ItemGroup>
    <PackageReference Include="System.Diagnostics.DiagnosticSource" />
    <PackageReference Include="System.IO.Pipelines" />
    <!-- Referenced for $(PkgSystem_ValueTuple) path only; ExcludeAssets="runtime"
         keeps it out of the build output (it is shipped via PackSystemValueTuple). -->
    <PackageReference Include="System.ValueTuple"
                      GeneratePathProperty="true"
                      ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Diagnostics.Runtime" />
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies"
                      PrivateAssets="All" />
    <PackageReference Include="MessagePack" />
    <PackageReference Include="MessagePack.Annotations" />
    <PackageReference Include="Lib.Harmony" />
    <ProjectReference Include="$(SolutionDir)\MTGOSDK\MTGOSDK.csproj" />
    <ProjectReference Include="$(SolutionDir)\MTGOSDK.Win32\MTGOSDK.Win32.csproj" />
  </ItemGroup>

  <!-- WPF assemblies for Dispatcher support -->
  <ItemGroup>
    <Reference Include="WindowsBase" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
  </ItemGroup>

</Project>